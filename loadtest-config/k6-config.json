{
  "baseUrl": "http://localhost",
  "endpoints": {
    "getAllProducts": {
      "path": "/api/product",
      "method": "GET",
      "description": "Ambil semua produk tanpa filter"
    },

    "getProductsWithRange": {
      "path": "/api/product",
      "method": "GET",
      "params": {
        "filter": "filter"
      },
      "testValues": {
        "filter": {
          "minPrice": 1000,
          "maxPrice": 500000
        }
      },
      "description": "Ambil produk dengan filter rentang harga 1000 -- 500000"
    },

    "getProductsWithFilter": {
      "path": "/api/product",
      "method": "GET",
      "params": {
        "filter": "filter"
      },
      "testValues": {
        "filter": {
          "categories": ["1"]
        }
      },
      "description": "Ambil produk dengan filter kategori"
    },

    "getProductsWithSearch": {
      "path": "/api/product",
      "method": "GET",
      "params": {
        "search": "search"
      },
      "testValues": {
        "search": "laptop"
      },
      "description": "Ambil produk berdasarkan query pencarian"
    }
  },

  "database": {
    "type": "postgresql",
    "host": "localhost",
    "port": 5433,
    "name": "Tokped",
    "user": "Minped",
    "password": "semogatubesinilancarselaluu",

    "schema": {
      "tables": {
        "user": "users",
        "store": "stores",
        "product": "products",
        "category": "categories",
        "categoryItem": "category_items"
      },

      "columns": {
        "user": {
          "id": "user_id",
          "email": "email",
          "password": "password",
          "role": "role",
          "name": "name",
          "address": "address",
          "balance": "balance",
          "createdAt": "created_at",
          "updatedAt": "updated_at"
        },
        "store": {
          "id": "store_id",
          "userId": "user_id",
          "name": "store_name",
          "description": "store_description",
          "logoPath": "store_logo_path",
          "balance": "balance",
          "createdAt": "created_at",
          "updatedAt": "updated_at"
        },
        "product": {
          "id": "product_id",
          "storeId": "store_id",
          "name": "product_name",
          "description": "description",
          "price": "price",
          "stock": "stock",
          "imagePath": "main_image_path",
          "createdAt": "created_at",
          "updatedAt": "updated_at",
          "deletedAt": "deleted_at"
        },
        "category": {
          "id": "category_id",
          "name": "name"
        },
        "categoryItem": {
          "categoryId": "category_id",
          "productId": "product_id"
        }
      },

      "additionalColumns": {
        "user": [],
        "store": [],
        "product": [],
        "category": [],
        "categoryItem": []
      }
    }
  },

  "seeding": {
    "enabled": true,
    "productsCount": 10000,
    "categoriesCount": 5,
    "storesCount": 10,

    "customValues": {
      "product": {
        "stock": {
          "type": "random",
          "min": 10,
          "max": 100
        }
      }
    }
  },

  "loadTest": {
    "stages": [
      { "duration": "10s", "target": 20 },
      { "duration": "30s", "target": 50 },
      { "duration": "10s", "target": 20 }
    ],

    "thresholds": {
      "http_req_duration": ["avg<8000", "p(90)<12000", "p(95)<25000"],
      "http_req_failed": ["rate<0.01"],
      "http_req_duration{scenario:getAllProducts}": [
        "avg<6000",
        "p(90)<10000",
        "p(95)<12000"
      ],
      "http_req_duration{scenario:getProductsWithRange}": [
        "avg<6000",
        "p(90)<10000",
        "p(95)<12000"
      ],
      "http_req_duration{scenario:getProductsWithFilter}": [
        "avg<5000",
        "p(90)<9000",
        "p(95)<10000"
      ],
      "http_req_duration{scenario:getProductsWithSearch}": [
        "avg<25000",
        "p(90)<35000",
        "p(95)<40000"
      ],
      "http_req_failed{scenario:getAllProducts}": ["rate<0.01"],
      "http_req_failed{scenario:getProductsWithRange}": ["rate<0.01"],
      "http_req_failed{scenario:getProductsWithFilter}": ["rate<0.01"],
      "http_req_failed{scenario:getProductsWithSearch}": ["rate<0.01"]
    }
  },

  "validation": {
    "checkStatusCode": true,
    "checkNonEmptyResponse": true,
    "expectedFields": ["status", "data"],
    "minimumProducts": 1
  }
}
